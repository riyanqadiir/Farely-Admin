# Admin backend port
ADMIN_API_PORT=4001

# CORS allowlist for admin frontend
# Comma-separated. Default Vite port is 3000; if that is taken, Vite uses 3001 — list both for local dev.
ADMIN_FRONTEND_URL=http://localhost:3000,http://localhost:3001

# Shared Mongo URI (same cluster for app_db + admin_db)
MONGO_URI=mongodb://127.0.0.1:27017

# Logical DB names within the same Mongo cluster (case-sensitive).
# If APP_DB_NAME is omitted, the first path segment of MONGO_URI is used (e.g.
# mongodb://127.0.0.1:27017/Farely → app DB Farely). Set explicitly if URI has no DB path.
APP_DB_NAME=Farely
ADMIN_DB_NAME=admin_db

# Admin auth
ADMIN_JWT_SECRET=replace-with-strong-secret
ADMIN_ACCESS_TTL=15m
ADMIN_REFRESH_TTL_DAYS=30

# Seed admin user created on first start (if not exists)
ADMIN_SEED_EMAIL=admin@farely.app
ADMIN_SEED_PASSWORD=Admin@12345

# Optional: smoke script overrides
ADMIN_SMOKE_BASE_URL=http://localhost:4001
ADMIN_SMOKE_EMAIL=admin@farely.app
ADMIN_SMOKE_PASSWORD=Admin@12345

# Brevo — copy the same block into Farely app backend .env if you use one account
# API key: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=
# Verified sender (must be a domain/sender approved in Brevo)
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=Farely
# Transactional webhooks (delivered, opened, …): create webhook in Brevo → URL below, then paste signing secret
# POST https://<your-admin-host>/webhooks/brevo/events
BREVO_WEBHOOK_SECRET=
# Inbound parsing: MX to Brevo for *@<BREVO_INBOUND_DOMAIN>, then inbound webhook URL:
# POST https://<your-admin-host>/webhooks/brevo/inbound?token=<BREVO_INBOUND_TOKEN>
BREVO_INBOUND_DOMAIN=reply.yourdomain.com
BREVO_INBOUND_TOKEN=
# Optional local-part prefix for per-thread Reply-To (default farely → farely+<threadMongoId>@domain)
BREVO_INBOUND_LOCAL_PREFIX=farely
# When a customer emails this address with no existing thread, a new support thread is created (e.g. support@yourdomain.com)
BREVO_PUBLIC_SUPPORT_EMAIL=farely.support@gmail.com
