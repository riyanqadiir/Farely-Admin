# Admin backend base URL used by the dashboard frontend.
# Local dev default backend: http://localhost:4001
VITE_ADMIN_API_URL=http://localhost:4001

# Google Maps JavaScript API key (Hotspots page). Enable Maps JavaScript API + billing in Google Cloud.
# If unset, the Hotspots map falls back to OpenStreetMap + Leaflet.
# VITE_GOOGLE_MAPS_API_KEY=
